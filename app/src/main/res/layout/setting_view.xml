<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/margin_home_views_settings">

    <ImageView
        android:id="@+id/try_plugin_button"
        style="@style/AppTextView"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="@dimen/margin_home_views_settings_tryout"
        android:contentDescription="@string/desc_try_plugin"
        android:scaleType="fitEnd"
        android:src="@mipmap/audio_gray" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginTop="50dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="0dp"
        android:paddingTop="30dp"
        android:scrollbars="none"
        tools:ignore="VisualLintSystemWindow">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/frame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/settingsTitle"
                    style="@style/AppTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:gravity="start"
                    android:labelFor="@id/spinner"
                    android:scrollHorizontally="false"
                    android:text="@string/settings_title"
                    android:textColor="@color/textColorSecondary"
                    android:textSize="@dimen/title_text_size" />

                <Spinner
                    android:id="@+id/spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/plugin_spinner_height"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:entries="@array/test" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/setting_plugin_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="@dimen/margin_home_views_settings_spinner_margin"
                android:layout_marginEnd="@dimen/margin_home_views_settings_spinner_margin"
                android:orientation="vertical"
                android:paddingTop="@dimen/margin_home_views_settings_plugin_top"
                android:paddingBottom="40dp" />
        </LinearLayout>
    </ScrollView>

</RelativeLayout>