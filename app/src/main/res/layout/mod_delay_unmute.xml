<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/enabledLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:paddingStart="25dp"
    android:paddingEnd="25dp"
    android:paddingBottom="30dp"
    tools:ignore="VisualLintSystemWindow">

    <TextView
        android:id="@+id/enableSubtext"
        style="@style/AppTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/delay_unmute_description"
        android:textColor="#C4BCAF"
        android:textSize="@dimen/normal_text_small" />

    <android.support.v7.widget.AppCompatSeekBar
        android:id="@+id/delay_unmute_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:max="6"
        android:progress="0" />

    <TextView
        android:id="@+id/unmutetext2"
        style="@style/AppTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:scrollHorizontally="false"
        android:text="@string/delay_unmute_default_value"
        android:textAlignment="center"
        android:textColor="#C4BCAF"
        android:textSize="@dimen/normal_text_small" />

</LinearLayout>