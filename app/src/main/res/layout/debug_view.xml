<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/crash_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="30dp"
    tools:context=".view.setting.SettingsActivity">

    <LinearLayout
        android:id="@+id/aboutLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center|start"
        android:orientation="vertical">

        <TextView
            android:id="@+id/debugTitle"
            style="@style/AppTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollHorizontally="false"
            android:text="@string/debug_title"
            android:textColor="@color/textColorSecondary"
            android:textSize="@dimen/title_text_size" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/debug_info1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:scrollHorizontally="false"
            android:text="@string/debug_info_text"
            android:textColor="@color/textColorSecondary"
            android:textSize="@dimen/normal_text_size" />

        <TextView
            android:id="@+id/debugInfo2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:scrollHorizontally="false"
            android:text="@string/debug_send_logs_title"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/normal_text_size" />

    </LinearLayout>
</LinearLayout>